# =====================================================================
# Secu Deck Bots — 환경 변수 예시
# ---------------------------------------------------------------------
# 실제 값은 .env 파일에 두고 절대 커밋하지 말 것.
# Railway 배포 시에는 대시보드 Variables 탭에서 동일한 키로 설정.
# =====================================================================

# ----------------- Discord -----------------
# 봇별로 다른 토큰 (5개 봇 = 5개 토큰)
DISCORD_BOT_TOKEN_PITCH=
DISCORD_BOT_TOKEN_CODE=
DISCORD_BOT_TOKEN_INTERVIEW=
DISCORD_BOT_TOKEN_DESIGN=
DISCORD_BOT_TOKEN_COS=
DISCORD_BOT_TOKEN_AUDIT=

# Secu Deck 디스코드 서버 ID (개발 중 길드 동기화 속도용, 모든 봇 공통)
DISCORD_GUILD_ID=

# 자가 점검 봇이 리포트 게시할 채널 ID (#self-audit)
SELF_AUDIT_CHANNEL_ID=

# ----------------- LLM API Keys -----------------
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# ----------------- GitHub -----------------
# Code Sentinel / Self-Audit 의 PR 처리에 사용. read-only 권한만 부여할 것.
GITHUB_PAT=
# Self-Audit Webhook 서명 검증용 시크릿
GITHUB_WEBHOOK_SECRET=

# ----------------- Postgres (Phase 2부터) -----------------
# Railway Postgres 추가 시 자동 주입
DATABASE_URL=

# ----------------- Cost / Quota -----------------
# 봇별 월 KRW 한도 (router 가 90% 도달 시 경고, 100% 도달 시 비핵심 차단)
COST_MONTHLY_LIMIT_KRW_PITCH=25000
COST_MONTHLY_LIMIT_KRW_CODE=80000
COST_MONTHLY_LIMIT_KRW_INTERVIEW=15000
COST_MONTHLY_LIMIT_KRW_DESIGN=25000
COST_MONTHLY_LIMIT_KRW_COS=30000
COST_MONTHLY_LIMIT_KRW_AUDIT=15000

# ----------------- 내부 봇 간 통신 (Phase 3+) -----------------
# Chief of Staff 가 다른 봇의 /api/invoke 를 호출할 때 사용하는 공유 시크릿
INTERNAL_API_SECRET=

# ----------------- 로깅 -----------------
LOG_LEVEL=INFO
